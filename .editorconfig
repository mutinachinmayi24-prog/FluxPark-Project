root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.{html,jinja,jinja2}]
indent_size = 2

[*.{js,css,scss,json,yml,yaml,toml}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.po]
insert_final_newline = false

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf
