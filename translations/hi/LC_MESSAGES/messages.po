#: app.py:407 app.py:1180
msgid "This invite link is invalid or has expired."
msgstr "यह इनवाइट लिंक अमान्य है या समाप्त हो गया है।"

#: app.py:415
msgid "Please choose email or phone."
msgstr "कृपया ईमेल या फ़ोन चुनें।"

#: app.py:417
msgid "Please enter a valid email address."
msgstr "कृपया एक मान्य ईमेल पता दर्ज करें।"

#: app.py:419
msgid "Please enter a valid 10-digit mobile number."
msgstr "कृपया एक मान्य 10-अंकीय मोबाइल नंबर दर्ज करें।"

#: app.py:451
msgid "Your OTP has expired. Please request a new one."
msgstr "आपका OTP समाप्त हो गया है। कृपया नया OTP प्राप्त करें।"

#: app.py:453
msgid "Incorrect OTP. Please try again."
msgstr "गलत OTP। कृपया पुनः प्रयास करें।"

#: app.py:498
msgid "Please select a property type."
msgstr "कृपया एक प्रॉपर्टी प्रकार चुनें।"

#: app.py:525
msgid "Please select Apartment or Gated Community."
msgstr "कृपया अपार्टमेंट या गेटेड कम्युनिटी चुनें।"

#: app.py:527 app.py:579
msgid "Please enter the property name."
msgstr "कृपया प्रॉपर्टी का नाम दर्ज करें।"

#: app.py:529 app.py:581
msgid "Please enter the address."
msgstr "कृपया पता दर्ज करें।"

#: app.py:531
msgid "Number of flats must be a number."
msgstr "फ्लैट्स की संख्या एक नंबर होनी चाहिए।"

#: app.py:533
msgid "Extra parking spaces must be a number."
msgstr "अतिरिक्त पार्किंग स्थानों की संख्या एक नंबर होनी चाहिए।"

#: app.py:593
#, python-format
msgid "Please enter valid numbers for company '%(name)s'."
msgstr "कृपया कंपनी '%(name)s' के लिए मान्य संख्याएं दर्ज करें।"

#: app.py:606
msgid "Please add at least one company."
msgstr "कृपया कम से कम एक कंपनी जोड़ें।"

#: app.py:671
msgid "Please select your company to continue."
msgstr "जारी रखने के लिए कृपया अपनी कंपनी चुनें।"

#: app.py:697
msgid "Please select a role."
msgstr "कृपया एक भूमिका चुनें।"

#: app.py:877
msgid "Please fill in all required fields."
msgstr "कृपया सभी आवश्यक फ़ील्ड भरें।"

#: app.py:882
msgid "Please enter your vehicle type and number for self-transport."
msgstr "सेल्फ-ट्रांसपोर्ट के लिए कृपया अपना वाहन प्रकार और नंबर दर्ज करें।"

#: app.py:887
msgid "Please fill in all required bank details."
msgstr "कृपया सभी आवश्यक बैंक विवरण भरें।"

#: app.py:891
msgid "Please add at least one vehicle."
msgstr "कृपया कम से कम एक वाहन जोड़ें।"

#: app.py:896
#, python-format
msgid "Vehicle number(s) already registered to another member: %(numbers)s"
msgstr ""
"वाहन नंबर पहले से ही किसी अन्य सदस्य के नाम पर पंजीकृत है: %(numbers)s"

#: app.py:901
#, python-format
msgid "Vehicle number %(number)s is already registered to another member."
msgstr "वाहन नंबर %(number)s पहले से ही किसी अन्य सदस्य के नाम पर पंजीकृत है।"

#: app.py:906
msgid "This Employee ID is already registered."
msgstr "यह कर्मचारी आईडी पहले से ही पंजीकृत है।"

#: app.py:1120
msgid "Profile updated successfully."
msgstr "प्रोफ़ाइल सफलतापूर्वक अपडेट हो गई।"

#: app.py:1168
#, python-format
msgid "Switched to %(name)s."
msgstr "%(name)s पर स्विच किया गया।"

#: app.py:1202
#, python-format
msgid "You're already part of %(name)s."
msgstr "आप पहले से %(name)s का हिस्सा हैं।"

#: app.py:1237 app.py:2472
msgid "Please enter the visitor's name."
msgstr "कृपया विज़िटर का नाम दर्ज करें।"

#: app.py:1239 app.py:2474
msgid "Please enter a valid 10-digit visitor phone number."
msgstr "कृपया विज़िटर का मान्य 10-अंकीय फ़ोन नंबर दर्ज करें।"

#: app.py:1241 app.py:1438 app.py:2476
msgid "Please select a vehicle type."
msgstr "कृपया एक वाहन प्रकार चुनें।"

#: app.py:1243 app.py:1440 app.py:2478
msgid "Please enter the vehicle number."
msgstr "कृपया वाहन नंबर दर्ज करें।"

#: app.py:1245 app.py:1318
msgid "Please fill in date, from time and to time."
msgstr "कृपया तारीख़, प्रारंभ समय और समाप्ति समय भरें।"

#: app.py:1265
msgid "Visitor request created and a parking slot was allocated!"
msgstr "विज़िटर रिक्वेस्ट बनाई गई और एक पार्किंग स्लॉट आवंटित किया गया!"

#: app.py:1267
msgid "Visitor request created. We'll notify you once a slot is available."
msgstr "विज़िटर रिक्वेस्ट बनाई गई। स्लॉट उपलब्ध होने पर हम आपको सूचित करेंगे।"

#: app.py:1316
msgid "Please select a valid parking slot of yours."
msgstr "कृपया अपना एक मान्य पार्किंग स्लॉट चुनें।"

#: app.py:1324
msgid "Rent per hour must be greater than zero."
msgstr "प्रति घंटा किराया शून्य से अधिक होना चाहिए।"

#: app.py:1326
msgid "Please enter a valid rent per hour."
msgstr "कृपया प्रति घंटा एक मान्य किराया दर्ज करें।"

#: app.py:1343
msgid "Slot listed and already matched with a waiting visitor!"
msgstr ""
"स्लॉट सूचीबद्ध किया गया और प्रतीक्षारत विज़िटर के साथ मैच कर दिया गया!"

#: app.py:1345
msgid "Your parking slot has been listed as available."
msgstr "आपका पार्किंग स्लॉट उपलब्ध के रूप में सूचीबद्ध कर दिया गया है।"

#: app.py:1378
msgid "This slot isn't currently matched with a visitor."
msgstr "यह स्लॉट अभी किसी विज़िटर के साथ मैच नहीं हुआ है।"

#: app.py:1382
msgid "Marked as returned. We've notified everyone affected."
msgstr ""
"वापस आने के रूप में चिह्नित किया गया। हमने सभी प्रभावित लोगों को सूचित कर "
"दिया है।"

#: app.py:1415
msgid "There's no pending request for tomorrow to cancel."
msgstr "रद्द करने के लिए कल का कोई लंबित रिक्वेस्ट नहीं है।"

#: app.py:1417 templates/transport_request.html:37
msgid "The 9 PM cutoff has passed; this request can no longer be changed."
msgstr ""
"रात 9 बजे की समय सीमा बीत चुकी है; इस रिक्वेस्ट को अब बदला नहीं जा सकता।"

#: app.py:1421
msgid "Transport request for tomorrow cancelled."
msgstr "कल के लिए ट्रांसपोर्ट रिक्वेस्ट रद्द कर दी गई।"

#: app.py:1425
msgid "You've already submitted a transport request for tomorrow."
msgstr "आप पहले से ही कल के लिए ट्रांसपोर्ट रिक्वेस्ट सबमिट कर चुके हैं।"

#: app.py:1428
msgid "Requests for tomorrow's parking must be submitted before 9 PM today."
msgstr ""
"कल की पार्किंग के लिए रिक्वेस्ट आज रात 9 बजे से पहले सबमिट करना आवश्यक है।"

#: app.py:1442
msgid "Please fill in your shift start and end time."
msgstr "कृपया अपनी शिफ्ट का प्रारंभ और समाप्ति समय भरें।"

#: app.py:1458
msgid ""
"Transport request for tomorrow submitted. Slots are allocated after the 9 PM"
" cutoff."
msgstr ""
"कल के लिए ट्रांसपोर्ट रिक्वेस्ट सबमिट कर दी गई। रात 9 बजे की समय सीमा के बाद"
" स्लॉट आवंटित किए जाते हैं।"

#: app.py:1527
#, python-format
msgid "Duplicate slot number '%(slot_number)s' in the table."
msgstr "टेबल में डुप्लीकेट स्लॉट नंबर '%(slot_number)s' है।"

#: app.py:1535
#, python-format
msgid "Entrance/ramp rank for slot '%(slot_number)s' must be a number."
msgstr "स्लॉट '%(slot_number)s' के लिए एंट्रेंस/रैंप रैंक एक नंबर होना चाहिए।"

#: app.py:1565 app.py:1576
#, python-format
msgid "Slot number '%(slot_number)s' is already in use."
msgstr "स्लॉट नंबर '%(slot_number)s' पहले से उपयोग में है।"

#: app.py:1596
msgid "Parking layout updated."
msgstr "पार्किंग लेआउट अपडेट कर दिया गया।"

#: app.py:1745 app.py:1774
msgid "This request has already been processed."
msgstr "इस रिक्वेस्ट पर पहले ही कार्रवाई हो चुकी है।"

#: app.py:1757
#, python-format
msgid "Approved %(name)s and allocated a parking slot."
msgstr "%(name)s को स्वीकृत किया गया और एक पार्किंग स्लॉट आवंटित किया गया।"

#: app.py:1759
#, python-format
msgid "Approved %(name)s. We'll notify you once a slot is available."
msgstr ""
"%(name)s को स्वीकृत किया गया। स्लॉट उपलब्ध होने पर हम आपको सूचित करेंगे।"

#: app.py:1786
#, python-format
msgid "Denied entry for %(name)s."
msgstr "%(name)s के लिए एंट्री अस्वीकृत कर दी गई।"

#: app.py:1856
msgid "This payment has already been processed."
msgstr "इस पेमेंट पर पहले ही कार्रवाई हो चुकी है।"

#: app.py:1867
msgid "Marked as paid."
msgstr "भुगतान किया गया के रूप में चिह्नित किया गया।"

#: app.py:1916
msgid "You cannot remove yourself."
msgstr "आप स्वयं को नहीं हटा सकते।"

#: app.py:1926
msgid "Member removed."
msgstr "सदस्य हटा दिया गया।"

#: app.py:2136
msgid ""
"Sorry, I couldn't reach the AI provider. Check your AI settings and try "
"again."
msgstr ""
"क्षमा करें, AI प्रोवाइडर तक नहीं पहुँच सका। अपनी AI सेटिंग्स जाँचें और फिर "
"से प्रयास करें।"

#: app.py:2196
#, python-format
msgid "Connected to Ollama at %(host)s. Installed models: %(models)s"
msgstr "%(host)s पर Ollama से कनेक्ट हो गया। इंस्टॉल किए गए मॉडल: %(models)s"

#: app.py:2197
msgid "none"
msgstr "कोई नहीं"

#: app.py:2202
#, python-format
msgid "Could not reach Ollama at %(host)s: %(error)s"
msgstr "%(host)s पर Ollama तक नहीं पहुँच सका: %(error)s"

#: app.py:2206
msgid "AI settings saved."
msgstr "AI सेटिंग्स सहेजी गईं।"

#: app.py:2311
msgid "No pass found for that code."
msgstr "उस कोड के लिए कोई पास नहीं मिला।"

#: app.py:2350
msgid "This visitor cannot be marked as entered right now."
msgstr "इस विज़िटर को अभी प्रवेश के रूप में चिह्नित नहीं किया जा सकता।"

#: app.py:2356
#, python-format
msgid "%(name)s marked as entered."
msgstr "%(name)s को प्रवेश के रूप में चिह्नित किया गया।"

#: app.py:2371
msgid "This visitor cannot be marked as exited right now."
msgstr "इस विज़िटर को अभी निकास के रूप में चिह्नित नहीं किया जा सकता।"

#: app.py:2377
#, python-format
msgid "%(name)s marked as exited."
msgstr "%(name)s को निकास के रूप में चिह्नित किया गया।"

#: app.py:2411
msgid "This pass cannot be marked as entered right now."
msgstr "इस पास को अभी प्रवेश के रूप में चिह्नित नहीं किया जा सकता।"

#: app.py:2417
msgid "Marked as entered."
msgstr "प्रवेश के रूप में चिह्नित किया गया।"

#: app.py:2432
msgid "This pass cannot be marked as exited right now."
msgstr "इस पास को अभी निकास के रूप में चिह्नित नहीं किया जा सकता।"

#: app.py:2438
msgid "Marked as exited."
msgstr "निकास के रूप में चिह्नित किया गया।"

#: app.py:2480
msgid "Please select a date."
msgstr "कृपया एक तारीख़ चुनें।"

#: app.py:2488
msgid "Please select who the visitor is here to see."
msgstr "कृपया चुनें कि विज़िटर किससे मिलने आया है।"

#: app.py:2497
msgid "Please enter the from and to time."
msgstr "कृपया प्रारंभ और समाप्ति समय दर्ज करें।"

#: app.py:2547
msgid "Visitor logged. Waiting for resident approval."
msgstr "विज़िटर दर्ज किया गया। निवासी की स्वीकृति की प्रतीक्षा है।"

