# Copy this file to .env and adjust values for your environment.
# .env is git-ignored - never commit real secrets.

# Flask session signing key. MUST be set to a long random value in production.
SECRET_KEY=change-this-to-a-long-random-secret-key

# Optional: standard Flask runtime settings
# FLASK_APP=app.py
# FLASK_DEBUG=true

# --- AI Assistant -----------------------------------------------------------
# AI provider settings (Ollama host/model, or BYOK base URL/API key/model) are
# configured per-user from the in-app "AI Settings" page and stored in the
# database (see AISettings in models.py) - they are NOT read from environment
# variables. The values below are listed here for reference only.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# BYOK_BASE_URL=https://api.openai.com/v1
# BYOK_API_KEY=
# BYOK_MODEL=gpt-4o-mini
