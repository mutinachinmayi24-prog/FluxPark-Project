# Copy this file to .env and adjust values for your environment.
# .env is git-ignored - never commit real secrets.

# Session signing key. MUST be set to a long random value in production.
SECRET_KEY=change-this-to-a-long-random-secret-key

# Optional: SQLAlchemy database URL. Defaults to a local SQLite file.
# DATABASE_URL=sqlite:///instance/database.db

# Optional: comma-separated hostnames TrustedHostMiddleware will accept.
# Defaults to "*" (unrestricted) for local/dev use - set this in production.
# ALLOWED_HOSTS=fluxpark.example.com

# --- AI Assistant -----------------------------------------------------------
# AI provider settings (Ollama host/model, BYOK base URL/API key/model, or
# Gemini API key/model) are configured per-user from the in-app "AI Settings"
# page and stored in the database (see AISettings in models.py) - they are
# NOT read from environment variables.
